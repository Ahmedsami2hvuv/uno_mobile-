@echo off
title Delete node_modules and run
cd /d "%~dp0"

echo Closing any process using node...
taskkill /f /im node.exe 2>nul
timeout /t 2 /nobreak >nul

echo Deleting node_modules...
if exist "node_modules" (
    rmdir /s /q "node_modules"
    if exist "node_modules" (
        echo Could not delete. Try: Right-click this file - Run as administrator
        pause
        exit /b 1
    )
    echo node_modules deleted.
) else (
    echo node_modules not found.
)

echo.
echo Starting Run-Uno...
call "%~dp0Run-Uno.bat"
pause
