@echo off
title حذف node_modules (شغّل كمسؤول)
cd /d "%~dp0"

echo ============================================
echo   تحديث المشروع إلى SDK 54
echo   يجب تشغيل هذا الملف كمسؤول
echo ============================================
echo.

net session >nul 2>&1
if %errorlevel% neq 0 (
    echo [تحذير] لم يُشغّل كمسؤول.
    echo.
    echo أغلق هذه النافذة، ثم:
    echo كليك يمين على هذا الملف --^> تشغيل كمسؤول
    echo.
    pause
    exit /b 1
)

echo إيقاف عمليات Node...
taskkill /f /im node.exe 2>nul
timeout /t 2 /nobreak >nul

echo.
echo جاري حذف node_modules...
if exist "node_modules" (
    rmdir /s /q "node_modules"
    if exist "node_modules" (
        echo فشل الحذف. جرّب إعادة تشغيل الكمبيوتر ثم نفّذ مرة أخرى.
        pause
        exit /b 1
    )
    echo تم حذف node_modules بنجاح.
) else (
    echo المجلد غير موجود.
)

echo.
echo ============================================
echo   الخطوة التالية:
echo   انقر نقرتين على Run-Uno وانتظر التثبيت (5-10 دقائق)
echo ============================================
echo.
pause
